# Firebase Admin SDK - Service account key path
# Puedes usar GOOGLE_APPLICATION_CREDENTIALS o FIREBASE_SERVICE_ACCOUNT_KEY
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# O alternativamente, pegar el JSON completo de la service account:
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ID del proyecto Firebase
FIREBASE_PROJECT_ID=tu-proyecto-id

# Opcional: Database URL si usas Realtime Database
# FIREBASE_DATABASE_URL=https://tu-proyecto.firebaseio.com
