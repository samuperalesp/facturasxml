{
  "name": "facturas-xml",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n front,server -c blue,green \"vite\" \"cd server && npm run dev\"",
    "dev:front": "vite",
    "dev:server": "cd server && npm run dev",
    "build": "tsc -b && vite build && cd server && npm run build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/file-saver": "^2.0.7",
    "file-saver": "^2.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
